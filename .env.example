# =============================================================================
# GOV-AI 2.0 — Configuration d'environnement
# Copier ce fichier vers .env et adapter les valeurs
# =============================================================================

# --- Application ---
APP_NAME=gov-ai-2
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
SECRET_KEY=changeme-super-secret-key-at-least-32-chars
API_V1_PREFIX=/api/v1

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=govai2
POSTGRES_USER=govai
POSTGRES_PASSWORD=govai_secret
DATABASE_URL=postgresql+asyncpg://govai:govai_secret@localhost:5432/govai2

# --- Milvus (Vector DB) ---
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_CHUNKS=govai_chunks
MILVUS_DIM=1024
MILVUS_INDEX_TYPE=HNSW
MILVUS_METRIC_TYPE=COSINE
MILVUS_NLIST=128
MILVUS_EF=64

# --- Elasticsearch (BM25) ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_CHUNKS=govai_chunks_bm25
ELASTICSEARCH_USER=
ELASTICSEARCH_PASSWORD=

# --- Neo4j (Sprint 2) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret
NEO4J_DATABASE=govai

# --- LLM (Ollama local) ---
LLM_PROVIDER=ollama           # ollama | openai-compatible
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1:70b        # llama3.1:70b | qwen2.5:72b | mistral-large
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_STREAM=true

# --- Embedding ---
EMBEDDING_PROVIDER=local      # local | ollama
EMBEDDING_MODEL=Qwen/Qwen3-Embedding   # ou BAAI/bge-m3
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu          # cpu | cuda | mps

# --- Reranker ---
RERANKER_MODEL=Qwen/Qwen3-Reranker    # ou BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_TOP_K=20

# --- Retrieval ---
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5
RRF_K=60
RERANKER_WEIGHT_SCORE=0.85
RERANKER_WEIGHT_META=0.15

# --- Generation ---
CITATION_MIN_SCORE=0.5
MIN_CHUNKS_FOR_ANSWER=1
CONFIDENCE_THRESHOLD=0.6      # τ_conf : refus si < seuil
ESCALATION_THRESHOLD=0.3      # τ_esc : escalade si < seuil

# --- Ingestion ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_FILE_SIZE_MB=50
SUPPORTED_LANGUAGES=fr,en
DOCUMENTS_PATH=./storage/documents
OCR_CACHE_PATH=./storage/ocr_cache
MODEL_CACHE_PATH=./storage/model_cache

# --- OCR ---
OCR_ENGINE=tesseract          # tesseract | paddleocr
TESSERACT_PATH=/usr/bin/tesseract
TESSERACT_LANG=fra+eng

# --- Security ---
JWT_SECRET_KEY=changeme-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# --- Evaluation ---
EVAL_DATASET_PATH=./eval/datasets/qa_bilingual_annotated.json
EVAL_REPORTS_PATH=./eval/reports
EVAL_TOP_K_VALUES=1,3,5,10

# --- Logging ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json               # json | text
LOG_FILE=./logs/govai.log
